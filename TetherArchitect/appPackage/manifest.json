{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.26/MicrosoftTeams.schema.json",
    "manifestVersion": "1.26",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Spectre Labs",
        "websiteUrl": "https://spectrelabs.dev",
        "privacyUrl": "https://spectrelabs.dev/privacy",
        "termsOfUseUrl": "https://spectrelabs.dev/terms"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "TETHER_ARCHITECT${{APP_NAME_SUFFIX}}",
        "full": "Tether Project Orchestrator Agent"
    },
    "description": {
        "short": "Orchestrator overseeing Tether operations",
        "full": "TETHER_ARCHITECT governs the Tether Household OS, manages sub-agents, tracks dependencies, and enforces GSD methodology."
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "composeExtensions": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "copilotAgents": {
        "declarativeAgents": [            
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "validDomains": []
}